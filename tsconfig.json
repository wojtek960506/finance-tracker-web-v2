      "@transactions/*": ["src/features/transactions/*"],
      "@test-utils/*": ["src/test-utils/*"],
      "@test-utils": ["src/test-utils/index.ts"],
      "@named-resources/*": ["src/features/named-resources/*"]
    }
  }
